---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import HomeSection from '../components/HomeSection.astro';

const docs = await getCollection('docs');

const getItems = (prefix: string) => 
  docs
    .filter((item) => item.id.startsWith(`${prefix}/`))
    .slice(0, 4);

const sections = [
  { title: 'Panduan', prefix: 'panduan', href: '/panduan/' },
  { title: 'Regulasi', prefix: 'regulasi', href: '/regulasi/' },
  { title: 'FAQ', prefix: 'faq', href: '/faq/' },
];
---

<StarlightPage
  frontmatter={{
    title: 'Panduan KIR',
    description: 'Panduan praktis uji berkala kendaraan bermotor',
    template: 'splash',
    hero: {
      title: 'Panduan KIR Kendaraan',
      tagline: 'Catatan dan panduan praktis seputar uji berkala kendaraan bermotor.',
    },
  }}
>
  {sections.map(section => (
    <HomeSection 
      title={section.title} 
      items={getItems(section.prefix)} 
      moreHref={section.href} 
    />
  ))}

  <hr />

  <div class="home-section">
    <h2>Tentang Website Ini</h2>
    <p>
      Panduan KIR dibuat sebagai catatan dan panduan praktis
      seputar uji berkala kendaraan bermotor.
    </p>
    <p>
      Website ini berisi penjelasan sederhana mengenai regulasi,
      prosedur, dan istilah yang sering digunakan dalam pengujian
      kendaraan, dengan pendekatan yang lebih mudah dipahami
      oleh masyarakat umum.
    </p>
    <p>
      Beberapa pembahasan juga dilengkapi dengan dasar regulasi
      serta catatan praktis berdasarkan pengalaman di lapangan.
    </p>
  </div>
</StarlightPage>
